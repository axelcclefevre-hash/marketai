# .env.example — Copiez ce fichier en .env et remplissez vos clés API

# Clé API Anthropic (obligatoire pour les analyses Claude)
# Obtenez la vôtre sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé API FRED (optionnelle, pour les obligations US)
# Inscription gratuite sur : https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
